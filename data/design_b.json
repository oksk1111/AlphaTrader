{
  "designSystem": {
    "meta": {
      "theme": "dark fintech dashboard",
      "analysisSource": "single screenshot",
      "precisionMode": "high-confidence visual approximation",
      "notes": [
        "Hover, focus, disabled, and loading states are inferred from visible styling patterns.",
        "Typography family cannot be proven from the screenshot; use a modern grotesk sans-serif.",
        "Spacing and radius values are estimated from visible proportions."
      ]
    },
    "globalTokens": {
      "colors": {
        "canvas": "#191B1F",
        "sidebarSurface": "#16181C",
        "topbarSurface": "#1D2025",
        "contentSurface": "#23262C",
        "cardSurface": "#1C1F24",
        "cardSurfaceElevated": "#20242A",
        "inputSurface": "#1F2227",
        "segmentedSurface": "#2A2E34",
        "divider": "#2E3239",
        "borderSubtle": "#343943",
        "textPrimary": "#F5F7FA",
        "textSecondary": "#A7ADB7",
        "textMuted": "#757B85",
        "textInverse": "#1A1B1F",
        "accentGold": "#F5C75B",
        "accentGoldStrong": "#F0BA3F",
        "accentGoldSoft": "#B28A2E",
        "positive": "#1FCB7B",
        "negative": "#EA4E5A",
        "whiteSoft": "#F3F4F6",
        "blackSoft": "#121316"
      },
      "gradients": {
        "ctaGold": {
          "type": "linear",
          "angle": "180deg",
          "stops": [
            { "color": "#FFD46C", "position": "0%" },
            { "color": "#F5C75B", "position": "55%" },
            { "color": "#EAB544", "position": "100%" }
          ],
          "css": "linear-gradient(180deg, #FFD46C 0%, #F5C75B 55%, #EAB544 100%)"
        },
        "chartAreaGold": {
          "type": "linear",
          "angle": "180deg",
          "stops": [
            { "color": "rgba(245,199,91,0.42)", "position": "0%" },
            { "color": "rgba(245,199,91,0.18)", "position": "58%" },
            { "color": "rgba(245,199,91,0.02)", "position": "100%" }
          ],
          "css": "linear-gradient(180deg, rgba(245,199,91,0.42) 0%, rgba(245,199,91,0.18) 58%, rgba(245,199,91,0.02) 100%)"
        },
        "sidebarWalletPanel": {
          "type": "linear",
          "angle": "180deg",
          "stops": [
            { "color": "#23262C", "position": "0%" },
            { "color": "#1C1F24", "position": "100%" }
          ],
          "css": "linear-gradient(180deg, #23262C 0%, #1C1F24 100%)"
        }
      },
      "shadows": {
        "cardLow": "0 8px 20px rgba(0,0,0,0.20)",
        "cardMedium": "0 12px 28px rgba(0,0,0,0.28)",
        "buttonGlowGold": "0 6px 18px rgba(245,199,91,0.18)",
        "chartGlowGold": "0 0 18px rgba(245,199,91,0.28)",
        "overlayInset": "inset 0 1px 0 rgba(255,255,255,0.03)"
      },
      "radii": {
        "shell": "0px",
        "panel": "14px",
        "control": "10px",
        "pill": "999px",
        "small": "8px"
      },
      "borders": {
        "default": "1px solid #2E3239",
        "activeAccent": "1px solid #F5C75B",
        "softLight": "1px solid rgba(255,255,255,0.05)"
      },
      "typography": {
        "display": {
          "color": "#F5F7FA",
          "weight": 700,
          "tracking": "-0.02em"
        },
        "heading": {
          "color": "#F5F7FA",
          "weight": 600
        },
        "body": {
          "color": "#A7ADB7",
          "weight": 400
        },
        "label": {
          "color": "#757B85",
          "weight": 500,
          "sizeBehavior": "small uppercase or compact sentence case"
        },
        "numericEmphasis": {
          "color": "#F5F7FA",
          "weight": 700
        },
        "positiveInline": {
          "color": "#1FCB7B",
          "weight": 600
        },
        "negativeInline": {
          "color": "#EA4E5A",
          "weight": 600
        }
      }
    },
    "layoutArchitecture": {
      "structure": [
        {
          "region": "appShell",
          "surface": "#191B1F",
          "children": ["sidebar", "mainColumn"]
        },
        {
          "region": "sidebar",
          "surface": "#16181C",
          "widthBehavior": "fixed",
          "children": ["brand", "primaryNav", "walletPanel"]
        },
        {
          "region": "mainColumn",
          "surface": "#23262C",
          "children": ["topbar", "assetHeader", "tabNav", "contentGrid"]
        },
        {
          "region": "contentGrid",
          "layout": "2-column desktop",
          "leftColumn": ["chartCard", "marketStatsCard"],
          "rightColumn": ["tradeCard", "newsCard"]
        }
      ],
      "spacingSystem": {
        "outerPadding": "16-24px",
        "cardGap": "16px",
        "internalCardPadding": "18-24px",
        "compactControlGap": "8-12px"
      },
      "layering": {
        "zIndexOrder": [
          { "layer": "baseShell", "z": 0 },
          { "layer": "cards", "z": 1 },
          { "layer": "stickyTopbar", "z": 2 },
          { "layer": "floatingControlsBadges", "z": 3 },
          { "layer": "menusTooltips", "z": 10 }
        ]
      }
    },
    "componentStyles": {
      "sidebar": {
        "container": {
          "surfaceColor": "#16181C",
          "borderRight": "1px solid #2A2E34",
          "shadow": "none"
        },
        "brandMark": {
          "logoColor": "#F5C75B",
          "wordmarkColor": "#F5C75B"
        },
        "navItem": {
          "default": {
            "surface": "transparent",
            "textColor": "#A7ADB7",
            "iconColor": "#A7ADB7",
            "radius": "10px"
          },
          "active": {
            "surface": "#23262C",
            "textColor": "#F5F7FA",
            "iconColor": "#F5F7FA",
            "indicator": "no left rail; full-row filled state"
          },
          "hover": {
            "surface": "#1E2126",
            "textColor": "#F5F7FA",
            "iconColor": "#F5F7FA"
          },
          "disabled": {
            "surface": "transparent",
            "textColor": "#5D626C",
            "iconColor": "#5D626C",
            "opacity": 0.55
          }
        },
        "walletPanel": {
          "surfaceColor": "linear-gradient(180deg, #23262C 0%, #1C1F24 100%)",
          "borderTreatment": "#2E3239",
          "elevationShadow": "0 12px 28px rgba(0,0,0,0.28)",
          "radius": "14px",
          "tokenBubble": {
            "surface": "#2A2E34",
            "iconContainer": "solid circular swatch",
            "iconBorder": "none"
          },
          "balancePanel": {
            "surface": "#17191D",
            "textPrimary": "#F5F7FA",
            "textSecondary": "#A7ADB7",
            "radius": "10px"
          }
        }
      },
      "topbar": {
        "container": {
          "surfaceColor": "#1D2025",
          "borderBottom": "1px solid #2E3239"
        },
        "breadcrumb": {
          "primaryText": "#F5F7FA",
          "secondaryText": "#A7ADB7"
        },
        "marketTicker": {
          "labelColor": "#A7ADB7",
          "positiveValue": "#1FCB7B",
          "negativeValue": "#EA4E5A",
          "separator": "#343943"
        },
        "utilityIcons": {
          "defaultSurface": "#23262C",
          "iconColor": "#F3F4F6",
          "radius": "999px",
          "hoverSurface": "#2A2E34"
        }
      },
      "assetHeader": {
        "assetIdentity": {
          "iconContainer": {
            "surface": "#F7931A",
            "iconColor": "#FFFFFF",
            "shape": "circle"
          },
          "nameText": "#F5F7FA",
          "tickerText": "#757B85"
        },
        "priceBlock": {
          "priceColor": "#F5F7FA",
          "deltaPositive": "#1FCB7B",
          "deltaNegative": "#EA4E5A"
        },
        "utilityActions": {
          "secondaryButton": {
            "surface": "#2A2E34",
            "textColor": "#F3F4F6",
            "iconColor": "#D7DAE0",
            "border": "1px solid #343943",
            "radius": "10px"
          },
          "secondaryButtonHover": {
            "surface": "#31363E"
          },
          "iconOnlyButton": {
            "surface": "#2A2E34",
            "iconColor": "#D7DAE0"
          }
        }
      },
      "tabNavigation": {
        "underlineTabs": {
          "defaultText": "#757B85",
          "activeText": "#F5F7FA",
          "activeUnderline": "#F3F4F6",
          "hoverText": "#D7DAE0",
          "underlineThickness": "2px"
        }
      },
      "cards": {
        "baseCard": {
          "surfaceColor": "#1C1F24",
          "borderTreatment": "#2E3239",
          "elevationShadow": "0 8px 20px rgba(0,0,0,0.20)",
          "radius": "14px"
        },
        "chartCard": {
          "surfaceColor": "#1C1F24",
          "contentElements": {
            "segmentedControl": {
              "containerSurface": "#2A2E34",
              "defaultText": "#A7ADB7",
              "activeSurface": "#F3F4F6",
              "activeText": "#1A1B1F",
              "hoverSurface": "#353A42",
              "radius": "8px"
            },
            "chartGrid": {
              "lineColor": "rgba(255,255,255,0.08)",
              "emphasisAxis": "rgba(255,255,255,0.28)"
            },
            "chartSeries": {
              "lineColor": "#F5C75B",
              "lineWidth": "3px",
              "pointStroke": "#F5C75B",
              "pointFill": "#1C1F24",
              "pointHoverFill": "#F5C75B",
              "glow": "0 0 18px rgba(245,199,91,0.28)"
            },
            "chartArea": {
              "fill": "linear-gradient(180deg, rgba(245,199,91,0.42) 0%, rgba(245,199,91,0.18) 58%, rgba(245,199,91,0.02) 100%)"
            },
            "tooltip": {
              "surface": "#F3F4F6",
              "textColor": "#1A1B1F",
              "shadow": "0 10px 24px rgba(0,0,0,0.24)",
              "radius": "999px"
            },
            "miniRangeOverview": {
              "baseArea": "rgba(255,255,255,0.05)",
              "activityArea": "rgba(255,255,255,0.14)",
              "handle": "#A7ADB7"
            }
          }
        },
        "tradeCard": {
          "surfaceColor": "#1C1F24",
          "tabSwitcher": {
            "containerSurface": "#2A2E34",
            "activeSurface": "#F3F4F6",
            "activeText": "#1A1B1F",
            "inactiveText": "#A7ADB7"
          },
          "conversionText": {
            "primaryValue": "#F5F7FA",
            "secondaryValue": "#757B85"
          },
          "fieldGroup": {
            "labelColor": "#A7ADB7",
            "fieldSurface": "#1F2227",
            "fieldBorder": "#2E3239",
            "fieldText": "#757B85",
            "suffixControlSurface": "transparent",
            "suffixText": "#F3F4F6",
            "tokenBadgeAccent": "#4C8DFF"
          },
          "primaryCta": {
            "surfaceColor": "linear-gradient(180deg, #FFD46C 0%, #F5C75B 55%, #EAB544 100%)",
            "textColor": "#1A1B1F",
            "shadow": "0 6px 18px rgba(245,199,91,0.18)",
            "radius": "999px"
          },
          "primaryCtaHover": {
            "surfaceColor": "linear-gradient(180deg, #FFDB7B 0%, #F7CB62 55%, #EDBC4E 100%)",
            "transform": "translateY(-1px)"
          },
          "primaryCtaPressed": {
            "surfaceColor": "#EAB544",
            "shadow": "0 2px 8px rgba(245,199,91,0.16)"
          }
        },
        "newsCard": {
          "surfaceColor": "#1C1F24",
          "headingColor": "#F5F7FA",
          "bodyText": "#D7DAE0",
          "metaText": "#757B85",
          "accentIconUse": "small circular badges retain saturated brand hues while text remains neutral"
        },
        "marketStatsCard": {
          "labelColor": "#A7ADB7",
          "valueColor": "#F5F7FA",
          "trendPositive": "#1FCB7B",
          "trendNegative": "#EA4E5A",
          "trackColor": "#343943",
          "progressAccent": "#F5C75B"
        }
      },
      "icons": {
        "systemIcons": {
          "default": "#D7DAE0",
          "muted": "#757B85",
          "inverseOnLight": "#1A1B1F",
          "accentUsage": "#F5C75B"
        },
        "tokenIcons": {
          "renderingRule": "use native token brand fills inside circular containers; never inherit container gradient"
        }
      }
    },
    "contextualStylingRules": [
      {
        "rule": "Navigation containers use flat dark surfaces; gradients are reserved for wallet summary and primary CTA surfaces."
      },
      {
        "rule": "Primary action buttons use gold gradient Gamma; utility buttons use solid neutral dark Delta with subtle border."
      },
      {
        "rule": "Large financial values use `textPrimary`; performance deltas exclusively use `positive` or `negative` semantic colors."
      },
      {
        "rule": "Cards receive shadows at the container level only; internal rows, labels, and chart elements remain shadow-free except chart glow and CTA glow."
      },
      {
        "rule": "Segmented controls use a dark track with a light selected chip; underline tabs use transparent backgrounds with a thin active line."
      },
      {
        "rule": "Accent gold should not be reused for body copy; reserve it for charting, CTA emphasis, selection accents, and branded highlights."
      }
    ],
    "hierarchicalStyleRelationships": {
      "inheritance": [
        "All cards inherit `baseCard` surface, border, radius, and low elevation shadow.",
        "Interactive chip controls inherit shared segmented treatment, then override active fill based on context.",
        "Numeric emphasis inherits heading weight but overrides size and tracking for price displays."
      ],
      "overrides": [
        "Tooltip surfaces invert from dark theme to light surface for immediate chart readability.",
        "Primary CTA overrides global control radius to fully pill-shaped.",
        "Chart markers override standard icon treatment with accent stroke and dark center fill."
      ],
      "responsiveBehavior": [
        "Desktop uses a persistent left sidebar and two-column content grid.",
        "On smaller widths, trade card likely stacks below chart card and sidebar collapses to icons or drawer.",
        "Ticker strip should permit horizontal overflow or truncation rather than wrapping into multiple rows."
      ]
    },
    "visualTreatmentInventory": {
      "shadowDistribution": [
        { "target": "cards", "shadow": "0 8px 20px rgba(0,0,0,0.20)" },
        { "target": "wallet summary panel", "shadow": "0 12px 28px rgba(0,0,0,0.28)" },
        { "target": "primary CTA", "shadow": "0 6px 18px rgba(245,199,91,0.18)" },
        { "target": "chart series", "shadow": "0 0 18px rgba(245,199,91,0.28)" }
      ],
      "radiusDistribution": [
        { "target": "cards", "radius": "14px" },
        { "target": "inputs and utility buttons", "radius": "10px" },
        { "target": "segmented active chips", "radius": "8px" },
        { "target": "CTA and tooltip pills", "radius": "999px" }
      ],
      "animationPatterns": [
        {
          "target": "nav items, utility buttons, segmented controls",
          "transition": "background-color 160ms ease, color 160ms ease, border-color 160ms ease"
        },
        {
          "target": "primary CTA",
          "transition": "transform 140ms ease, box-shadow 180ms ease, background 180ms ease"
        },
        {
          "target": "chart points",
          "transition": "transform 120ms ease, fill 120ms ease, stroke 120ms ease"
        }
      ]
    },
    "stateArchitecture": {
      "navigationItem": {
        "default": {
          "surface": "transparent",
          "text": "#A7ADB7",
          "icon": "#A7ADB7"
        },
        "hover": {
          "surface": "#1E2126",
          "text": "#F5F7FA",
          "icon": "#F5F7FA"
        },
        "active": {
          "surface": "#23262C",
          "text": "#F5F7FA",
          "icon": "#F5F7FA"
        },
        "focus": {
          "outline": "2px solid rgba(245,199,91,0.55)",
          "outlineOffset": "2px"
        },
        "disabled": {
          "opacity": 0.55,
          "text": "#5D626C",
          "icon": "#5D626C"
        }
      },
      "segmentedControlOption": {
        "default": {
          "surface": "transparent",
          "text": "#A7ADB7"
        },
        "hover": {
          "surface": "#353A42",
          "text": "#F3F4F6"
        },
        "selected": {
          "surface": "#F3F4F6",
          "text": "#1A1B1F"
        },
        "disabled": {
          "surface": "transparent",
          "text": "#5D626C",
          "opacity": 0.5
        }
      },
      "primaryButton": {
        "default": {
          "surface": "linear-gradient(180deg, #FFD46C 0%, #F5C75B 55%, #EAB544 100%)",
          "text": "#1A1B1F",
          "shadow": "0 6px 18px rgba(245,199,91,0.18)"
        },
        "hover": {
          "surface": "linear-gradient(180deg, #FFDB7B 0%, #F7CB62 55%, #EDBC4E 100%)",
          "transform": "translateY(-1px)"
        },
        "pressed": {
          "surface": "#EAB544",
          "shadow": "0 2px 8px rgba(245,199,91,0.16)",
          "transform": "translateY(0)"
        },
        "focus": {
          "outline": "2px solid rgba(255,212,108,0.50)",
          "outlineOffset": "3px"
        },
        "disabled": {
          "surface": "#6D6550",
          "text": "rgba(26,27,31,0.65)",
          "shadow": "none",
          "opacity": 0.65
        },
        "loading": {
          "surface": "#F5C75B",
          "text": "transparent",
          "spinner": "#1A1B1F"
        }
      },
      "secondaryButton": {
        "default": {
          "surface": "#2A2E34",
          "border": "#343943",
          "text": "#F3F4F6"
        },
        "hover": {
          "surface": "#31363E",
          "text": "#FFFFFF"
        },
        "pressed": {
          "surface": "#262A30"
        },
        "focus": {
          "outline": "2px solid rgba(243,244,246,0.22)"
        },
        "disabled": {
          "surface": "#23262C",
          "text": "#5D626C",
          "border": "#2A2E34"
        }
      },
      "textInput": {
        "default": {
          "surface": "#1F2227",
          "border": "#2E3239",
          "text": "#F5F7FA",
          "placeholder": "#757B85"
        },
        "hover": {
          "border": "#3A404A"
        },
        "focus": {
          "border": "#F5C75B",
          "shadow": "0 0 0 3px rgba(245,199,91,0.16)"
        },
        "error": {
          "border": "#EA4E5A",
          "supportText": "#EA4E5A"
        },
        "disabled": {
          "surface": "#1B1D21",
          "text": "#5D626C",
          "placeholder": "#5D626C"
        }
      }
    },
    "accessibility": {
      "contrastEstimates": [
        {
          "pair": "#F5F7FA on #1C1F24",
          "ratioApprox": 14.0,
          "compliance": "AAA"
        },
        {
          "pair": "#A7ADB7 on #1C1F24",
          "ratioApprox": 7.1,
          "compliance": "AAA"
        },
        {
          "pair": "#757B85 on #1C1F24",
          "ratioApprox": 4.1,
          "compliance": "AA large only; borderline for normal text"
        },
        {
          "pair": "#1A1B1F on #F5C75B",
          "ratioApprox": 10.2,
          "compliance": "AAA"
        },
        {
          "pair": "#1FCB7B on #1C1F24",
          "ratioApprox": 7.0,
          "compliance": "AAA"
        },
        {
          "pair": "#EA4E5A on #1C1F24",
          "ratioApprox": 4.6,
          "compliance": "AA"
        }
      ],
      "guidance": [
        "Use `textPrimary` for all standard body text over dark cards.",
        "Restrict `textMuted` to labels, timestamps, and tertiary metadata.",
        "Do not place gold body text on dark surfaces for long-form reading; reserve gold for emphasis and controls."
      ]
    },
    "implementationGuardrails": {
      "avoid": [
        "Applying gold gradients to icons, labels, or generic card backgrounds.",
        "Using button text color as default typography color across the layout.",
        "Placing drop shadows on individual text blocks or chart labels.",
        "Using the light selected-chip style for full navigation rows.",
        "Reusing semantic green/red for non-performance decorative accents."
      ],
      "ensure": [
        "Container shadows remain on outer cards, not internal content fragments.",
        "Gold appears as a controlled accent family across CTA, chart, and branded moments.",
        "Light-on-dark contrast is preserved for all primary reading surfaces.",
        "Selection patterns stay consistent: light chip for segmented controls, underline for content tabs, filled row for sidebar navigation.",
        "Form fields remain flatter and darker than surrounding cards to preserve depth hierarchy."
      ]
    }
  }
}